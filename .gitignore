# === Unity .gitignore ===
# See https://github.com/github/gitignore/blob/main/Unity.gitignore

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# User-specific files
.vs/
.vscode/
.idea/

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
MemoryCaptures/

# Autogenerated by Unity
UserSettings/
DerivedDataCache/

# Build results
*.apk
*.aab
*.unitypackage

# Visual Studio / Rider / MonoDevelop
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd

# Asset meta data should be tracked
# Do NOT ignore .meta files

# Crashlytics, Fabric, fastlane
crashlytics-build.properties

# Gradle / Android Studio
.gradle/
build/

# Unity Cache Server
Cache/

# Avoid committing large or transient files
*.log
*.tmp
*.bak

# Machine-specific files
local.properties

# Git LFS note: track large binary assets (textures, audio, models) with Git LFS
# Example:
#   git lfs install
#   git lfs track "*.psd" "*.png" "*.fbx" "*.wav" "*.mp4"
# Commit the generated .gitattributes file after tracking.
